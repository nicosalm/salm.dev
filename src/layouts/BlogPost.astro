---
import type { CollectionEntry } from 'astro:content';
import Layout from './Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import TableOfContents from '../components/blog_components/TableOfContents';
import { calculateReadingTime } from '../utils/readingTime';

type Props = {
    post: CollectionEntry<'blog'>;
    prevPost?: CollectionEntry<'blog'>;
    nextPost?: CollectionEntry<'blog'>;
};

const { post, prevPost, nextPost } = Astro.props;
const { title, pubDate, tags, image, description } = post.data;
const formattedDate = pubDate.toLocaleDateString('en-US', {
    month: 'short',
    day: '2-digit',
    year: 'numeric'
});

const readingTime = calculateReadingTime(post.body);
---


<Layout title={title}>
    {/* Add debug classes to each major container */}
    <div class="min-h-screen w-full overflow-x-hidden bg-black text-gray-300 debug-1">
        <Header />
        <main class="relative max-w-4xl mx-auto px-4 py-8 debug-2">
            {/* banner Image */}
            <div class="w-full h-[240px] bg-neutral-800 border border-neutral-700 mb-6 debug-3">
                {image ? (
                <img
                    src={image.url}
                    alt={image.alt || title}
                    class="w-full h-full object-cover"
                />
                ) : (
                <div class="w-full h-full flex items-center justify-center">
                    <div class="text-neutral-600 text-6xl font-ibm-vga">?</div>
                </div>
                )}
            </div>

            {/* article header */}
            <header class="mb-8 debug-4">
                <h1 class="text-3xl font-ibm-vga text-white mb-2">{title}</h1>
                <div class="h-px bg-red-500 mb-3" />

                <div class="flex items-center gap-4 text-red-500 mb-4 font-ibm-vga">
                    <span>⌗</span>
                    <time datetime={pubDate.toISOString()}>{formattedDate}</time>
                    <span class="text-neutral-500">~/time: {readingTime} min</span>
                </div>

                {description && (
                <p class="text-neutral-400 mb-4 font-ibm-vga">{description}</p>
                )}

                {tags.length > 0 && (
                <div class="flex flex-wrap gap-3">
                    {tags.map(tag => (
                    <span class="text-cyan-500 font-ibm-vga">#{tag}</span>
                    ))}
                </div>
                )}
            </header>

            {/* Content */}
            <article class="prose prose-invert prose-cyan max-w-none mb-12 font-iosevka overflow-x-hidden debug-5">
                <slot />
            </article>

            {/* Support Section */}
            <div class="border border-neutral-800 bg-neutral-900 p-4 mb-12 text-center font-ibm-vga flex items-center justify-center gap-4">
                <span>Like what you read?</span>
                <a
                    href="https://github.com/sponsors/nicosalm"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-2 text-cyan-400 hover:text-cyan-300"
                >
                    <span>♥</span>
                    <span>Support my work</span>
                </a>
            </div>

            {/* Post Navigation */}
            <nav class="border-t border-neutral-800 pt-6 pb-12 font-ibm-vga debug-7">
                <div class="flex justify-between items-start gap-4 mb-8">
                    {prevPost && (
                    <a href={`/blog/${prevPost.slug}`}
                        class="flex flex-col text-neutral-400 hover:text-cyan-400">
                        <span class="text-red-500">← Previous</span>
                        <span class="mt-2">{prevPost.data.title}</span>
                    </a>
                    )}
                    {nextPost && (
                    <a href={`/blog/${nextPost.slug}`}
                        class="flex flex-col text-right text-neutral-400 hover:text-cyan-400 ml-auto">
                        <span class="text-red-500">Next →</span>
                        <span class="mt-2">{nextPost.data.title}</span>
                    </a>
                    )}
                </div>
            </nav>
        </main>
        <Footer />
        <TableOfContents client:load />
    </div>
</Layout>


<style is:global>
.prose {
    /* Base Text */
    @apply leading-relaxed;

    /* Headings */
    h2, h3, h4, h5, h6 {
        @apply font-ibm-vga text-white;
        @apply flex items-center gap-2;
    }
    h2 { @apply text-2xl mt-12 mb-4; }
    h3 { @apply text-xl mt-8 mb-3; }
    h4 { @apply text-lg mt-6 mb-2; }

    /* Add terminal-like prefix to headings */
    h2::before { content: "##"; @apply text-red-500; }
    h3::before { content: "###"; @apply text-red-500; }
    h4::before { content: "####"; @apply text-red-500; }

    /* Links */
    a {
        @apply text-cyan-400 hover:text-cyan-300 no-underline;
    }

    /* Code Blocks */
    pre {
        @apply bg-black border border-neutral-700 rounded-none my-6 relative;
        @apply font-ibm-vga text-sm overflow-x-auto p-4;
    }

    /* Remove any syntax highlighting from our CSS since Shiki handles it */
    pre > code {
        @apply block;
    }

    /* inline code */
    :not(pre) > code {
        @apply font-ibm-vga text-cyan-400 bg-neutral-900 px-1.5 py-0.5 font-normal;
        @apply whitespace-normal break-words;
        &::before, &::after {
            content: none;
        }
    }


    /* Lists */
    ul, .footnotes ol {
        @apply my-4 pl-6 space-y-2;
        list-style-type: none;
    }

    ul li, .footnotes ol li {
        @apply relative;
    }

    /* Standard list bullets */
    ul li::before {
        content: "•";
        @apply text-red-500 absolute -left-4;
    }

    /* Footnote bullets - remove any extra punctuation */
    .footnotes ol li::before {
        content: "•";
        @apply text-red-500 absolute -left-4;
    }

    /* Hide default footnote numbers */
    .footnotes ol {
        list-style: none;
    }

    /* Remove the period that appears after the bullet */
    .footnotes ol li p {
        @apply ml-0;
        &::before {
            content: none;
        }
    }

    /* Blockquotes */
    blockquote {
        @apply border-l-2 border-red-500 pl-4 my-6 italic;
        @apply text-neutral-400;
    }

    /* Images */
    img {
        @apply max-w-full my-8 border border-neutral-800;
    }

    /* Tables */
    table {
        @apply w-full border-collapse my-6;
    }

    th {
        @apply text-left py-2 px-4 bg-neutral-900 border-b border-neutral-800;
        @apply font-ibm-vga text-white;
    }

    td {
        @apply py-2 px-4 border-b border-neutral-800;
    }

    /* Horizontal Rule */
    hr {
        @apply my-8 border-t border-neutral-800;
    }

    /* Paragraphs */
    p {
        @apply mb-4;
    }

    /* Fix spacing for code blocks within list items */
    li > pre {
        @apply my-2;
    }

    /* Fix consecutive code blocks */
    pre + pre {
        @apply mt-0;
    }
}
</style>
