<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" type="image/svg+xml" href="/assets/favicon.svg">
    <link rel="preload" href="/assets/fonts/source-serif-4-roman.woff2" as="font" type="font/woff2" crossorigin>
    <link rel="stylesheet" href="/styles/styles.css">
    <link rel="canonical" href="{{ site.url }}{{ page.url }}">
    <link rel="alternate" type="application/rss+xml" title="rss feed | salm.dev" href="/rss.xml">
    <title>{% if title %}{{ title }} | {{ site.title }}{% else %}{{ site.title }}{% endif %}</title>
    {% if description %}
    <meta name="description" content="{{ description }}">
    {% endif %}

    <meta property="og:title" content="{% if title %}{{ title }} | {{ site.title }}{% else %}{{ site.title }}{% endif %}">
    <meta property="og:description" content="{{ description | default(site.description) }}">
    <meta property="og:image" content="{{ site.url }}/assets/logo.png">
    <meta property="og:url" content="{{ site.url }}{{ page.url }}">
    <meta property="og:type" content="{% if layout == 'layouts/post.njk' %}article{% else %}website{% endif %}">

    {% if prefetch %}
    <link rel="preconnect" href="{{ prefetch }}">
    {% endif %}
    {% if math %}
    <script src="/assets/js/mathjax-config.js"></script>
    <script id="MathJax-script" async src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-chtml.js"></script>
    {% endif %}
</head>
<body>
    <a href="#main" class="skip-link">Skip to content</a>
    <header class="site-header">
        <a href="/" class="site-title">salm.dev</a>
        <nav>
            <a href="/now">now</a><span class="sep">|</span><a
            href="/writing">writing</a><span class="sep">|</span><a
            href="/about">about</a><span class="sep">|</span><a
            href="https://github.com/nicosalm/">code</a>
        </nav>
        <span class="spacer"></span>
        <span class="header-right">{% include "email.njk" %}</span>
    </header>
    <main id="main">
    {{ content | safe }}
    </main>
    <script
        src="https://rybbit.salm.dev/api/script.js"
        data-site-id="81989c7adfe0"
        defer
    ></script>
    <script src="https://instant.page/5.2.0" type="module" integrity="sha384-jnZyxPjiipYXnSU0ygqeac2q7CVYMbh84q0uHVRRxEtvFPiQYbXWUorga2aqZJ0z"></script>
    <script>
    document.querySelectorAll('[data-email]').forEach(function(el) {
        var e = el.dataset.email.split('').reverse().join('');
        var s = el.dataset.subject ? '?subject=' + encodeURIComponent(el.dataset.subject) : '';
        el.href = 'mailto:' + e + s;
    });
    </script>
</body>
</html>
