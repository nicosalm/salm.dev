---
layout: layouts/base.njk
---
<article>
    {% if featured or project %}
    <div class="post-ribbons">
        {% if featured %}<svg class="post-ribbon ribbon-selected" viewBox="0 0 14 60" aria-label="Selected"><path d="M0 0 L14 0 L14 52 L7 44 L0 52 Z" fill="currentColor"/><text x="7" y="22" transform="rotate(-90 7 22)" text-anchor="middle" class="ribbon-text">SELECTED</text></svg>{% endif %}
        {% if project %}<svg class="post-ribbon ribbon-project" viewBox="0 0 14 60" aria-label="Project"><path d="M0 0 L14 0 L14 52 L7 44 L0 52 Z" fill="currentColor"/><text x="7" y="22" transform="rotate(-90 7 22)" text-anchor="middle" class="ribbon-text">PROJECT</text></svg>{% endif %}
    </div>
    {% endif %}
    <h1>{{ title }}</h1>
    <div class="post-meta">
        <time class="post-date" datetime="{{ date | dateFormat }}">{{ date | monthYear }}</time>
        &middot; {{ content | readingTime }}
        {% if category %}&middot; <a href="/writing/?category={{ category }}">{{ category }}</a>{% endif %}
        {% if popular %}&middot; popular on {% for source, url in popular %}<a href="{{ url }}" rel="noopener">{{ source }}</a>{% if not loop.last %}, {% endif %}{% endfor %}{% endif %}
    </div>
    {% if description %}
    <p class="post-description">{{ description }}</p>
    {% endif %}
    {% if authorNote %}
    <details class="authors-note" open>
        <summary>Author's Note</summary>
        <div class="authors-note-content">
            {{ authorNote | safe }}
        </div>
    </details>
    {% endif %}
    {{ content | safe }}
    <div class="the-end">❦</div>
    <div class="post-navigation">
        {%- set previousPost = collections.posts | getNextCollectionItem(page) %}
        {%- set nextPost = collections.posts | getPreviousCollectionItem(page) %}
        {% if previousPost %}
        <div class="nav-prev">&larr; <a href="{{ previousPost.url }}">{{ previousPost.data.title }}</a></div>
        {% endif %}
        {% if nextPost %}
        <div class="nav-next"><a href="{{ nextPost.url }}">{{ nextPost.data.title }}</a> &rarr;</div>
        {% endif %}
    </div>
</article>
{% include "footer.njk" %}
<script src="/assets/js/toc.js" defer></script>
<script src="/assets/js/sidenotes.js" defer></script>
<script src="/assets/js/code-anchors.js" defer></script>
