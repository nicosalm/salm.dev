---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import { getCollection } from 'astro:content';
import ArchiveFilter from '../../../components/ArchiveFilter';

interface ProcessedPost {
  slug: string;
  data: {
    title: string;
    description?: string;
    pubDate: string;
  };
  body: string;
}

const posts = await getCollection('blog');

// process posts into the format expected by ArchiveFilter
const postsByYear = posts.reduce((acc, post) => {
    const year = post.data.pubDate.getFullYear().toString();
    if (!acc[year]) {
        acc[year] = [];
    }

    // transform post to format
    const processedPost: ProcessedPost = {
        slug: post.slug,
        data: {
            title: post.data.title,
            description: post.data.description,
            pubDate: post.data.pubDate.toISOString()
        },
        body: post.body
    };

    acc[year].push(processedPost);
    return acc;
}, {} as Record<string, ProcessedPost[]>);
---

<Layout title="[nico@salm.dev ~/blog/archive]$">
    <div class="min-h-screen bg-black text-gray-300">
        <Header />
        <main class="max-w-4xl mx-auto px-4 py-8">
            <nav class="mb-8 flex flex-col sm:flex-row items-center justify-center sm:space-x-16 space-y-4 sm:space-y-0 font-ibm-vga">
                <a href="/blog" class="text-red-500 hover:text-red-400 flex items-center gap-3">
                    <span>◆</span>
                    FEATURED
                </a>
                <a href="/blog/archive" class="text-red-500 hover:text-red-400 flex items-center gap-3">
                    <span>◆</span>
                    ARCHIVE
                </a>
                <a href="/blog/categories" class="text-red-500 hover:text-red-400 flex items-center gap-3">
                    <span>◆</span>
                    CATEGORIES
                </a>
                <a href="/blog/rss.xml" class="text-red-500 hover:text-red-400 flex items-center gap-3">
                    <span>◆</span>
                    RSS
                </a>
            </nav>

            <ArchiveFilter
                client:load
                postsByYear={postsByYear}
            />
        </main>
        <Footer />
    </div>
</Layout>

<style>
    input::placeholder {
        color: #525252;
    }

    input:focus {
        outline: none;
        box-shadow: none;
        border: none;
    }
</style>
