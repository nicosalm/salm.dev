---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
const sortedPosts = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Layout title="[nico@salm.dev ~/blog]$">
   <div class="min-h-screen bg-black text-gray-300">
       <Header />

       <main class="max-w-5xl mx-auto px-4 py-8">
           <nav class="mb-12 flex items-center justify-center space-x-12 font-ibm-vga">
               <a href="/blog" class="text-red-500 hover:text-red-400 flex items-center gap-2">
                   <span>◆</span>
                   ALL POSTS
               </a>
               <a href="/blog/categories" class="text-red-500 hover:text-red-400 flex items-center gap-2">
                   <span>◆</span>
                   CATEGORIES
               </a>
               <a href="/rss.xml" class="text-red-500 hover:text-red-400 flex items-center gap-2">
                   <span>◆</span>
                   RSS
               </a>
           </nav>

           <div class="space-y-16 max-w-4xl mx-auto">
               {sortedPosts.map((post) => (
                   <article class="grid grid-cols-[150px_1fr] gap-8">
                       <div class="w-[150px] h-[150px] bg-neutral-800 border border-neutral-700">
                           {post.data.image ? (
                               <img
                                   src={post.data.image.url}
                                   alt={post.data.image.alt || post.data.title}
                                   class="w-full h-full object-cover"
                               />
                           ) : (
                               <div class="w-full h-full flex items-center justify-center text-neutral-600 text-6xl font-ibm-vga">
                                   ?
                               </div>
                           )}
                       </div>

                       <div>
                           <h2 class="text-2xl font-ibm-vga mb-1">
                               <a href={`/blog/${post.slug}`} class="text-white hover:text-cyan-400">
                                   {post.data.title}
                               </a>
                           </h2>

                           <div class="h-px bg-red-500 mb-4" />

                           <div class="flex items-center gap-4 text-red-500 mb-4 font-ibm-vga">
                               <span>⌗</span>
                               <time>
                                   {post.data.pubDate.toLocaleDateString('en-US', {
                                       month: 'short',
                                       day: '2-digit',
                                       year: 'numeric'
                                   })}
                               </time>
                           </div>

                           <p class="text-neutral-400 mb-4 font-ibm-vga leading-relaxed">
                               {post.data.description}
                           </p>

                           <div class="flex flex-wrap gap-2">
                               {post.data.tags.map((tag) => (
                                   <span class="text-cyan-500 font-ibm-vga">#{tag}</span>
                               ))}
                           </div>
                       </div>
                   </article>
               ))}
           </div>
       </main>

       <Footer />
   </div>
</Layout>

<style>
   @media (max-width: 640px) {
       article {
           grid-template-columns: 1fr !important;
           gap: 1rem !important;
       }
   }
</style>
