---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact Nico">
    <div class="max-w-2xl mx-auto">
        <h1 class="text-3xl font-normal mb-4">Contact</h1>
        <p class="text-gray-600 dark:text-gray-400 mb-8">
            Have a question or want to get in touch? You can reach me at:
        </p>

        <p class="font-mono text-lg text-gray-800 dark:text-gray-200 mb-12">
            nico at salm.dev
        </p>

        <div class="mt-12 pt-8 border-t border-gray-200 dark:border-gray-800">
            <h2 class="text-xl font-normal mb-4">Other Ways to Connect</h2>
            <div class="space-y-2 text-gray-600 dark:text-gray-400">
                <p>
                    Find me on <a href="https://github.com/nicosalm" class="text-blue-600 hover:text-blue-800 dark:text-blue-400 dark:hover:text-blue-200">GitHub</a>
                    or <a href="https://twitter.com/salmdotdev" class="text-blue-600 hover:text-blue-800 dark:text-blue-400 dark:hover:text-blue-200">Twitter</a>.
                </p>
            </div>
        </div>
    </div>
</Layout>
