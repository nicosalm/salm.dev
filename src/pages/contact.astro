---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact Nico">
  <div class="max-w-2xl mx-auto space-y-8">
    <div class="space-y-2">
      <h1 class="text-3xl">Contact</h1>
      <p class="text-gray-600 dark:text-gray-400">Have a question or want to get in touch?</p>
    </div>

    <div class="space-y-4">
      <p class="font-mono">nico at salm.dev</p>

      <div class="pt-8 border-t dark:border-gray-800">
        <p class="text-gray-600 dark:text-gray-400">
          Find me on <a href="https://github.com/nicosalm" class="text-gray-900 dark:text-gray-100 hover:underline">GitHub</a> or
          <a href="https://twitter.com/salmdotdev" class="text-gray-900 dark:text-gray-100 hover:underline">Twitter</a>
        </p>
      </div>
    </div>
  </div>
</Layout>
