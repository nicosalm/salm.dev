---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="[nico@salm.dev ~]$">
    <div class="min-h-screen bg-black text-gray-300">
        <Header />
        <main class="max-w-4xl mx-auto px-4 py-8">
            {/* terminal intro */}
            <section class="mb-8">
                <div class="terminal-header mb-6 text-sm sm:text-base overflow-x-auto whitespace-nowrap">
                    <span class="text-cyan-400 font-ibm-vga">nico@salm.dev</span>
                    <span class="text-neutral-500 font-ibm-vga">:</span>
                    <span class="text-red-500 font-ibm-vga">~</span>
                    <span class="text-neutral-500 font-ibm-vga">$</span>
                    <span class="text-white font-ibm-vga"> tree /home/nico</span>
                </div>

                <div class="space-y-1 font-ibm-vga">
                    <p class="text-white">/home/nico</p>
                    <p class="ml-4">
                        <span class="text-neutral-500">├── </span>
                        <a href="/about" class="text-white hover:text-cyan-400">about/</a>
                        <span class="text-neutral-400 ml-2 text-sm">whois Nico</span>
                    </p>
                    <p class="ml-4"><span class="text-neutral-500">├── links/</span></p>
                    <p class="ml-8">
                        <span class="text-neutral-500">├── </span>
                        <a href="https://github.com/nicosalm" class="text-cyan-400 hover:text-cyan-300">github</a>
                    </p>
                    <p class="ml-8">
                        <span class="text-neutral-500">└── </span>
                        <a href="mailto:nico@salm.dev" class="text-cyan-400 hover:text-cyan-300">email</a>
                    </p>
                    <p class="ml-4">
                        <span class="text-neutral-500">├── projects/</span>
                    </p>
                    <p class="ml-8">
                        <span class="text-neutral-500">├── </span>
                        <a href="/blog" class="text-white hover:text-cyan-400">writing/</a>
                        <span class="text-neutral-400 ml-2 text-sm">hot takes and cool things</span>
                    </p>
                    <p class="ml-8">
                        <span class="text-neutral-500">└── </span>
                        <a href="/tools" class="text-white hover:text-cyan-400">tools/</a>
                        <span class="text-neutral-400 ml-2 text-sm">things I've built</span>
                    </p>
                    <p class="ml-4"><span class="text-neutral-500">└── docs/</span></p>
                </div>
            </section>
        </main>
        <Footer />
    </div>
</Layout>

<style>
    .terminal-header::after {
        content: "_";
        animation: blink 1s step-end infinite;
    }

    @keyframes blink {
        50% { opacity: 0; }
    }
</style>
