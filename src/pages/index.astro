---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
---

<Layout title="[nico@salm.dev ~]$">
    <div id="loading-container"></div>
    <div class="bg-black min-h-screen flex flex-col" id="content">
        <div class="fixed top-0 w-full">
            <Header />
        </div>

        <main class="flex-1 flex items-center justify-center p-4">
            <div class="w-full max-w-4xl">
                <div class="border border-neutral-800 bg-neutral-900/50 font-ibm-vga">
                    <div class="border-b border-neutral-800 p-2 flex items-center justify-between">
                        <div class="flex items-center gap-2">
                            <div class="w-3 h-3 rounded-full bg-red-500"></div>
                            <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
                            <div class="w-3 h-3 rounded-full bg-green-500"></div>
                        </div>
                        <div class="text-neutral-500 text-sm">bash - nico@salm.dev</div>
                        <div class="w-16"></div>
                    </div>

                    <div class="p-6 space-y-4">
                        <div>
                            <span class="text-cyan-400">nico@salm.dev</span>
                            <span class="text-neutral-500">:</span>
                            <span class="text-red-400">~</span>
                            <span class="text-neutral-500">$</span>
                            <span class="text-white"> whoami</span>
                        </div>

                        <div class="text-neutral-300">
                            Software Engineer and Data Scientist
                        </div>

                        <div class="h-4"></div>

                        <div>
                            <span class="text-cyan-400">nico@salm.dev</span>
                            <span class="text-neutral-500">:</span>
                            <span class="text-red-400">~</span>
                            <span class="text-neutral-500">$</span>
                            <span class="text-white"> ls projects/</span>
                        </div>

                        <div class="grid grid-cols-2 gap-4 text-neutral-300">
                            <div>
                                <span class="text-cyan-400">→</span> Data Engineering
                            </div>
                            <div>
                                <span class="text-red-400">→</span> ML/AI Development
                            </div>
                            <div>
                                <span class="text-yellow-400">→</span> System Design
                            </div>
                            <div>
                                <span class="text-green-400">→</span> Web Development
                            </div>
                        </div>

                        <div class="h-4"></div>

                        <div>
                            <span class="text-cyan-400">nico@salm.dev</span>
                            <span class="text-neutral-500">:</span>
                            <span class="text-red-400">~</span>
                            <span class="text-neutral-500">$</span>
                            <span class="text-white"> cat contact.txt</span>
                        </div>

                        <div class="space-y-2 text-neutral-300">
                            <div>• <a href="https://github.com/nicosalm" class="text-cyan-400 hover:text-cyan-300">GitHub</a></div>
                            <div>• <a href="/blog" class="text-cyan-400 hover:text-cyan-300">Blog</a></div>
                            <div>• <a href="/about" class="text-cyan-400 hover:text-cyan-300">More Info</a></div>
                        </div>
                        <div class="h-4"></div>

                        <div>
                            <span class="text-cyan-400">nico@salm.dev</span>
                            <span class="text-neutral-500">:</span>
                            <span class="text-red-400">~</span>
                            <span class="text-neutral-500">$</span>
                            <span class="blink text-white">_</span>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>
</Layout>

<script>
    const hasVisited = sessionStorage.getItem('hasVisited');
    const content = document.getElementById('content');

    if (!hasVisited) {
        const loadingContainer = document.getElementById('loading-container');

        if (content && loadingContainer) {
            loadingContainer.innerHTML = `
                <div class="fixed inset-0 bg-black flex items-center justify-center z-50 font-ibm-vga">
                    <div class="loading-text text-cyan-400">
                        <div id="status">INITIALIZING SYSTEM...</div>
                        <div class="mt-4">
                            <span id="progress">[                    ] 0%</span>
                        </div>
                        <div class="mt-4">
                            <span id="message">BOOT SEQUENCE STARTING</span><span class="blink">_</span>
                        </div>
                    </div>
                </div>
            `;

            sessionStorage.setItem('hasVisited', 'true');

            const messages = [
                'BOOT SEQUENCE STARTING',
                'LOADING MODULES',
                'CHECKING MEMORY',
                'LOADING RESOURCES',
                'STARTING SERVICES',
                'BOOT SEQUENCE COMPLETE'
            ];

            const progress = document.getElementById('progress');
            const message = document.getElementById('message');
            let currentBlock = 0;

            const updateProgress = () => {
                if (!progress || !message) return;

                if (currentBlock < 20) {
                    const blocks = '█'.repeat(currentBlock) + ' '.repeat(20 - currentBlock);
                    const percent = currentBlock * 5;
                    progress.textContent = `[${blocks}] ${percent}%`;
                    message.textContent = messages[Math.floor(currentBlock/4)];
                    currentBlock++;
                    setTimeout(updateProgress, 50);
                } else {
                    progress.textContent = `[${'█'.repeat(20)}] 100%`;
                    message.textContent = messages[messages.length - 1];
                    window.dispatchEvent(new CustomEvent('loading:complete'));
                }
            };

            updateProgress();

            window.addEventListener('loading:complete', () => {
                loadingContainer.classList.add('fade-out');
                setTimeout(() => {
                    loadingContainer.remove();
                    startTypingEffects();
                }, 500);
            });
        }
    } else {
        content?.classList.remove('hidden');
        startTypingEffects();
    }

    function startTypingEffects() {
        const elements = document.querySelectorAll<HTMLElement>('[class^="typing-effect-"]');
        elements.forEach((element) => {
            element.style.opacity = '0';
            setTimeout(() => {
                element.style.opacity = '1';
                element.classList.add('typing');
            }, delay);
            delay += 750;
        });
    }

</script>

<style>
.blink {
    animation: blink 1s step-end infinite;
}

@keyframes blink {
50% { opacity: 0; }
}

.fade-out {
    opacity: 0;
    transition: opacity 0.5s ease-out;
}
</style>
