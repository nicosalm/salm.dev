---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import profileImage from '../assets/images/me.jpeg';
---
<Layout title="Nico Salm">
    <div class="max-w-2xl mx-auto">
        <div class="grid md:grid-cols-5 gap-8">
            <div class="md:col-span-3 order-2 md:order-1 flex flex-col justify-center">
                <h1 class="font-serif font-normal text-3xl mb-4">About Me</h1>
                <div class="font-serif space-y-4">
                    <p>Hi, I'm Nico. Welcome to my website! I'm studying Computer Sciences and Data Science at the University of Wisconsin-Madison.</p>
                    <p>I'm interested in Data Systems and Game Theory, particularly their intersection in distributed systems and consensus protocols.</p>
                </div>
            </div>
            <div class="md:col-span-2 order-1 md:order-2">
                <div class="aspect-square w-full max-w-md mx-auto">
                    <Image
                        src={profileImage}
                        alt="Profile picture"
                        class="rounded-lg object-cover w-full h-full"
                        width={400}
                        height={400}
                        format="webp"
                        quality={90}
                    />
                </div>
            </div>
        </div>
    </div>
</Layout>
