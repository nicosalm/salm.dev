---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="[nico@salm.dev ~/about]$">
    <div class="min-h-screen bg-black text-gray-300">
        <Header />

        <main class="max-w-4xl mx-auto px-4 py-8">
            <section class="mb-8">
                <div class="terminal-header mb-6 text-sm sm:text-base overflow-x-auto whitespace-nowrap">
                    <span class="text-cyan-400 font-ibm-vga">nico@salm.dev</span>
                    <span class="text-neutral-500 font-ibm-vga">:</span>
                    <span class="text-red-500 font-ibm-vga">~/about</span>
                    <span class="text-neutral-500 font-ibm-vga">$</span>
                    <span class="text-white font-ibm-vga"> cat about.txt</span>
                </div>

                <div class="space-y-4 font-iosevka">
                    {/* header section */}
                    <div class="flex flex-col-reverse sm:flex-row sm:gap-8 items-center sm:items-start">
                        <div class="flex-1 mt-4 sm:mt-0">
                            <p class="text-base sm:text-lg text-center sm:text-left">
                                Hello! I'm Nico — a software engineer working at the intersection of systems, data, and ML.
                                I build tools and infrastructure for complex data problems.
                            </p>
                        </div>
                        <div class="w-40 h-40 sm:w-32 sm:h-32 flex-shrink-0 bg-neutral-800 border border-neutral-700">
                            <img
                                src="/images/me.jpeg"
                                alt="Nico Salm"
                                class="w-full h-full object-cover"
                            />
                        </div>
                    </div>

                    <div class="h-px bg-neutral-800 my-6"></div>

                    {/* grid section */}
                    <div class="grid grid-cols-1 sm:grid-cols-[120px_1fr] gap-4 sm:gap-6 font-ibm-vga">
                        <div class="text-cyan-400">INTERESTS</div>
                        <div class="space-y-2 text-sm sm:text-base">
                            <p>• Machine Learning & AI for Predictive Analytics</p>
                            <p>• Low-level Systems, Operating Systems, and UNIX</p>
                            <p>• Data Engineering & Analytics</p>
                        </div>

                        <div class="text-cyan-400 mt-4 sm:mt-0">TOOLS</div>
                        <div class="space-y-2 text-sm sm:text-base">
                            <p>• Languages: Python, Go, Rust, C++, SQL (<a href="https://wakatime.com/@nicosalm" class="text-cyan-400 hover:text-cyan-300">among others</a>)</p>
                            <p>• Cloud, Infra, and DevOps: AWS, GCP, Kafka, Docker</p>
                            <p>• Data: PyTorch, PostgreSQL, MongoDB, Pandas, Apache Spark, Hadoop</p>
                        </div>
                    </div>

                    <div class="h-px bg-neutral-800 my-6"></div>

                    <h2 class="text-xl sm:text-2xl font-ibm-vga text-white mb-3">Projects</h2>
                    <div class="space-y-3">
                        View my <a href="https://github.com/stars/nicosalm/lists/my-projects" class="text-cyan-400 hover:text-cyan-300">complete projects list</a> on GitHub! (pardon the redirect)
                    </div>
                    <div class="h-px bg-neutral-800 my-6"></div>

                    <div class="grid grid-cols-1 sm:grid-cols-[120px_1fr] gap-4 sm:gap-6 font-ibm-vga">
                        <div class="text-cyan-400">QUICK TIDBITS</div>
                        <div class="space-y-2 text-sm sm:text-base">
                            <p>• My primary code editor is Neovim (<a href="/blog/3-cli-productivity" class="text-cyan-400 hover:text-cyan-300">blog post</a> / <a href="https://github.com/nicosalm/nvim" class="text-cyan-400 hover:text-cyan-300">config</a>)</p>
                            <p>• I use <code>:colorscheme elflord</code></p>
                            <p>• Reading is fun</p>
                            <p>• I <a href="https://en.wikipedia.org/wiki/Dungeon_Master" class="text-cyan-400 hover:text-cyan-300">DM</a> for tabletop games & build fantasy worlds</p>
                            <p>• I enjoy deep / purposeful conversations but I'm not very good at smalltalk
                            <p>• Email me for my discord :)</p>
                            <br/>
                            <p> <i>If you read this, you now know a bit about me. Wow! ✨</i> </p>
                                <br/>
                        </div>
                    </div>

                    <div class="flex gap-4 justify-center sm:justify-start">
                        <a href="https://github.com/nicosalm" class="text-cyan-400 hover:text-cyan-300">GitHub</a>
                        <span class="text-neutral-500">◆</span>
                        <a href="mailto:nico@salm.dev" class="text-cyan-400 hover:text-cyan-300">Email</a>
                    </div>
                </div>
            </section>
        </main>

        <Footer />
    </div>
</Layout>

<style>
    .terminal-header::after {
        content: "_";
        animation: blink 1s step-end infinite;
    }

    @keyframes blink {
        50% { opacity: 0; }
    }

    :not(pre) > code {
        @apply font-ibm-vga text-cyan-400 bg-neutral-900 px-1.5 py-0.5 font-normal;
        @apply whitespace-normal break-words;
        &::before, &::after {
            content: none;
        }
    }
</style>
