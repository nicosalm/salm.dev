---
const navItems = [
    ['ABOUT', '/about'],
    ['BLOG', '/blog'],
    ['TOOLS', '/tools'],
    ['TUBE', 'https://www.youtube.com/@nicosalm'],
    ['CODE', 'https://github.com/nicosalm/'],
] as const;
interface Props {
    title?: string;
    author?: string;
}
const {
    title = "salm.dev",
    author = "nicosalm"
} = Astro.props;
const currentYear = new Date().getFullYear();
const version = `© ${currentYear} ${author}`;
---
<header class="bg-neutral-800 px-4 py-3 md:py-1">
    <div class="px-2 mx-auto grid grid-cols-2 md:grid-cols-3 justify-between items-center relative">

        {/* leftmost items ~ grid[0] */}
        <div class="justify-self-start tracking-[.3em]">
            <a href="/" class="text-cyan-400 font-ibm-vga hover:text-cyan-300 transition-colors">{title}</a>
        </div>

        {/* Mobile menu button */}
        <button
            id="mobile-menu-button"
            class="md:hidden justify-self-end text-gray-400 hover:text-cyan-400 text-2xl"
            aria-label="Toggle menu"
        >
            ☰
        </button>

        {/* center items ~ grid[1] */}
        <nav class="hidden md:flex absolute md:static top-full left-0 right-0 bg-neutral-800 md:bg-transparent
            justify-self-center items-center md:space-x-2 font-ibm-vga
            flex-col md:flex-row w-full md:w-auto py-2 md:py-0
            shadow-lg md:shadow-none"
            id="nav-menu"
        >
            {navItems.map(([text, href]) => (
            <a
                href={href}
                target={href.startsWith('http') ? '_blank' : undefined}
                rel={href.startsWith('http') ? 'noopener noreferrer' : undefined}
                class="flex items-center text-gray-400 hover:text-cyan-400 px-4 py-2 transition-colors group w-full md:w-auto text-center"
            >
                <span class="text-gray-600 group-hover:text-cyan-600 mr-1 transition-transform group-hover:-translate-x-1">&#91;</span>
                <span>{text}</span>
                <span class="text-gray-600 group-hover:text-cyan-600 ml-1 transition-transform group-hover:translate-x-1">&#93;</span>
            </a>
            ))}
        </nav>
        {/* rightmost items ~ grid[2] */}
        <div class="hidden md:block font-ibm-vga justify-self-end text-s text-cyan-400">{version}</div>
    </div>
</header>

<script>
const mobileMenuButton = document.getElementById('mobile-menu-button');
const navMenu = document.getElementById('nav-menu');

mobileMenuButton?.addEventListener('click', () => {
    navMenu?.classList.toggle('hidden');
});
</script>
