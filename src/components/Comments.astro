---
---

<section class="font-ibm-vga my-12">
    <div class="giscus-wrapper">
        <div class="giscus"></div>
        <div id="giscus-loading" class="text-neutral-500 hidden">Loading comments...</div>
        <div id="giscus-error" class="text-red-400 hidden">Failed to load comments. Please check your internet connection and refresh the page.</div>
    </div>
</section>

<script is:inline>
    function loadComments() {
        const script = document.createElement('script');
        const loadingEl = document.getElementById('giscus-loading');
        const errorEl = document.getElementById('giscus-error');

        loadingEl.classList.remove('hidden');

        script.src = 'https://giscus.app/client.js';
        script.setAttribute('data-repo', 'nicosalm/salm.dev');
        script.setAttribute('data-repo-id', 'R_kgDOLIwzgg');
        script.setAttribute('data-category', 'Blog Comments');
        script.setAttribute('data-category-id', 'DIC_kwDOLIwzgs4CcmA1');
        script.setAttribute('data-mapping', 'pathname');
        script.setAttribute('data-strict', '1');
        script.setAttribute('data-reactions-enabled', '1');
        script.setAttribute('data-emit-metadata', '0');
        script.setAttribute('data-input-position', 'bottom');
        script.setAttribute('data-theme', 'dark_high_contrast');
        script.setAttribute('data-lang', 'en');
        script.setAttribute('data-loading', 'lazy');
        script.crossOrigin = 'anonymous';
        script.async = true;

        script.onerror = () => {
            loadingEl.classList.add('hidden');
            errorEl.classList.remove('hidden');
        };

        script.onload = () => {
            loadingEl.classList.add('hidden');
        };

        const container = document.querySelector('.giscus');
        if (container) {
            container.appendChild(script);
        }
    }

    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                loadComments();
                observer.disconnect();
            }
        });
    });

    observer.observe(document.querySelector('.giscus-wrapper'));
</script>

<style is:global>
    .giscus-wrapper {
        @apply w-full mt-4;
    }

    .giscus {
        @apply w-full;
    }

    #giscus-loading, #giscus-error {
        @apply py-4 text-center font-ibm-vga;
    }

    :root {
        --giscus-text-color: #d1d5db !important;
        --giscus-border-color: #374151 !important;
        --giscus-primary-color: #22d3ee !important;
        --giscus-background-color: #000000 !important;
        --giscus-comment-box-bg: #111111 !important;
        --giscus-main-bg-color: #000000 !important;
        --giscus-btn-border-color: #374151 !important;
        --giscus-btn-bg-color: #111111 !important;
        --giscus-btn-hover-bg-color: #1f2937 !important;
        --giscus-btn-hover-border-color: #4b5563 !important;
        --giscus-input-bg: #111111 !important;
        --giscus-input-border: #374151 !important;
    }

    .giscus-frame {
        @apply w-full border-t border-neutral-800 !important;
    }

    .giscus-frame iframe {
        @apply bg-black !important;
    }
</style>
