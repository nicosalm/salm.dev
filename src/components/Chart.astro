---
interface Props {
    chart: string;
}

const { chart } = Astro.props;
---

<div class="chart-container" data-chart={chart}></div>

<script>
    import ApexCharts from 'apexcharts';

    function flipChartThemeMode(chartOptions: any, darkMode: boolean) {
        const theme = chartOptions.theme;
        const tooltip = chartOptions.tooltip;
        const chart = chartOptions.chart;

        return {
            ...chartOptions,
            chart: {
                ...chart,
                background: "rgba(0, 0, 0, 0)",
                fontFamily: "inherit",
            },
            theme: {
                ...theme,
                mode: darkMode ? "dark" : "light",
            },
            tooltip: {
                ...tooltip,
                theme: darkMode ? "dark" : "light",
            },
        };
    }

    function initializeCharts() {
        const isDark = document.documentElement.classList.contains('dark');

        document.querySelectorAll(".chart-container").forEach((chartDiv) => {
            const chartDataAttr = chartDiv.getAttribute("data-chart");
            if (chartDataAttr) {
                const chartData = JSON.parse(chartDataAttr);
                const chart = new ApexCharts(
                    chartDiv,
                    flipChartThemeMode(chartData, isDark)
                );
                chart.render();
            }
        });
    }

    function updateCharts() {
        const isDark = document.documentElement.classList.contains('dark');

        document.querySelectorAll(".chart-container").forEach((chartDiv) => {
            const chartDataAttr = chartDiv.getAttribute("data-chart");
            if (chartDataAttr) {
                const chartData = JSON.parse(chartDataAttr);
                const chartID = chartDiv.querySelector('.apexcharts-canvas')?.id;
                if (!chartID) return;

                const chart = ApexCharts.getChartByID(
                    chartID.replace("apexcharts", "")
                );
                if (chart) {
                    chart.updateOptions(
                        flipChartThemeMode(chartData, isDark)
                    );
                }
            }
        });
    }

    document.addEventListener("DOMContentLoaded", initializeCharts);

    const observer = new MutationObserver((mutations) => {
        mutations.forEach((mutation) => {
            if (mutation.attributeName === 'class') {
                updateCharts();
            }
        });
    });

    observer.observe(document.documentElement, {
        attributes: true,
        attributeFilter: ['class']
    });
</script>

<style is:global>
    .apexcharts-text {
        @apply text-gray-900 dark:text-gray-100;
    }

    .apexcharts-tooltip {
        @apply text-gray-900 dark:text-gray-100;
    }

    .apexcharts-legend-text {
        @apply text-gray-900 dark:text-gray-100 !important;
    }
</style>
