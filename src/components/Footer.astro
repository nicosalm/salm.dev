---
import childProcess from 'child_process';
const hash = childProcess.execSync('git rev-parse --short HEAD').toString().trim();
const repoUrl = 'https://github.com/nicosalm/salm.dev';
const commitUrl = `${repoUrl}/commit/${hash}`;
---

<footer class="container mx-auto p-4 max-w-screen-xl flex justify-between items-center">
  <p class="text-sm">&copy; {new Date().getFullYear()} Nico Salm</p>
  <div class="flex items-center">
    <a href="/rss.xml" class="rss-link mr-4 text-sm flex items-center" aria-label="RSS Feed">
      <i class="fa-solid fa-square-rss mr-1"></i>
      <span>RSS</span>
    </a>
    <p class="text-sm">
      Commit: 
      <a href={commitUrl} target="_blank" class="commit-link text-blue-600 hover:underline" rel="noopener noreferrer">
        {hash}
      </a>
    </p>
  </div>
</footer>

<style>
  footer {
    margin-top: 2rem;
    border-top: 1px solid var(--color-border);
  }
  .rss-link, .commit-link {
    color: var(--color-accent);
    text-decoration: none;
    transition: color 0.3s ease;
  }
  .rss-link:hover, .commit-link:hover {
    color: var(--color-primary);
  }
  .rss-link i {
    font-size: 1rem;
    vertical-align: middle;
  }
  .flex {
    display: flex;
  }
  .items-center {
    align-items: center;
  }
  .justify-between {
    justify-content: space-between;
  }
  .mr-4 {
    margin-right: 1rem;
  }
  .mr-1 {
    margin-right: 0.25rem;
  }
  .text-sm {
    font-size: 0.875rem;
  }
</style>
