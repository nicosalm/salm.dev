---
import commitData from '../data/commitHash.json';

const { hash } = commitData;

const {
    site = "salm.dev",
    author = "nicosalm"
} = Astro.props;

---
<footer class="fixed bottom-0 w-full bg-black border-t border-neutral-800">
    <div class="grid grid-cols-[1fr_auto_1fr] max-w-6xl mx-auto px-6 py-2">
        <div class="flex items-center gap-2 text-neutral-500 font-mono text-sm col-start-2">
            <a href="/" class="flex items-center gap-2 text-white hover:text-cyan-400 transition-colors duration-100">
                <span>&#60;&#60;&#60;</span>
                <span>{site}</span>
            </a>
            <span>/</span>
            <a
                class="commit-hash text-neutral-500 hover:text-custom-cyan transition-colors duration-100"
                href={`https://github.com/${author}/salm.dev/commit/${hash}`}
                target="_blank"
                aria-label="GitHub commit hash"
            >
                {hash}
            </a>
        </div>
    </div>
</footer>

<style>
  footer {
    background-color: #000;
    color: #fff;
  }

  .commit-hash {
    margin-left: 2px;
    color: #808080;
    text-decoration: none;
    font-size: 0.875rem;
    transition: color 0.2s ease;
  }

  .commit-hash:hover {
    color: rgb(34, 211, 238);
  }

  .commit-hash, .commit-hash + span {
    margin-left: 0;
  }
</style>

