---
interface Props {
    title: string;
    description: string;
    slug: string;
    postCount: number;
}

const { title, description, slug, postCount } = Astro.props;
---

<a href={`/collections/${slug}`} class="block p-4 border dark:border-gray-800 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-800/50 transition">
    <h3 class="text-lg font-medium">{title}</h3>
    <p class="text-sm text-gray-600 dark:text-gray-400 mt-1">{description}</p>
    <span class="text-sm text-gray-500 dark:text-gray-500 mt-2 inline-block">
        {postCount} {postCount === 1 ? 'post' : 'posts'}
    </span>
</a>
