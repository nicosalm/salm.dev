{
  "name": "github-dark",
  "type": "dark",
  "colors": {
    "editor.background": "#0d1117",
    "editor.foreground": "#c9d1d9"
  },
  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment", "string.comment"],
      "settings": {
        "foreground": "#8b949e"
      }
    },
    {
      "scope": [
        "constant",
        "entity.name.constant",
        "variable.other.constant",
        "variable.other.enummember",
        "variable.language",
        "support.constant"
      ],
      "settings": {
        "foreground": "#79c0ff"
      }
    },
    {
      "scope": ["entity.name", "entity.name.tag", "support.class"],
      "settings": {
        "foreground": "#7ee787"
      }
    },
    {
      "scope": ["variable.parameter.function", "variable.parameter"],
      "settings": {
        "foreground": "#ffa657"
      }
    },
    {
      "scope": ["storage.type", "storage.modifier"],
      "settings": {
        "foreground": "#ff7b72"
      }
    },
    {
      "scope": ["string", "punctuation.definition.string", "string.template"],
      "settings": {
        "foreground": "#a5d6ff"
      }
    },
    {
      "scope": ["punctuation", "meta.brace"],
      "settings": {
        "foreground": "#c9d1d9"
      }
    }
  ]
}
